# Optional: video iframe src when `videoEmbedSrc` in default-site-config.ts is empty
# NEXT_PUBLIC_VIDEO_EMBED_SRC=https://player.vimeo.com/video/123456789

# Optional: countdown target (ISO 8601) when `countdown.targetIso` is empty in config.
# If both are empty, the client uses a 7-day placeholder countdown.
# NEXT_PUBLIC_COUNTDOWN_TARGET=2026-05-18T20:00:00-04:00
