# Optional: fixed countdown target (ISO 8601). Used when site config `countdown.targetIso` is empty.
# If both are empty, the client shows a 7-day placeholder countdown — set a real time in Admin or here.
# NEXT_PUBLIC_COUNTDOWN_TARGET=2026-05-18T20:00:00-04:00

# Optional: video iframe src when site config `videoEmbedSrc` is empty
# NEXT_PUBLIC_VIDEO_EMBED_SRC=https://player.vimeo.com/video/123456789

# --- Admin (Vercel / local) ---
# Strong password for /admin — required to sign in
# ADMIN_PASSWORD=

# Upstash Redis (Vercel Marketplace → Redis → connect project)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Vercel Blob — for image/video uploads in admin (optional; URLs can be pasted manually)
# BLOB_READ_WRITE_TOKEN=
